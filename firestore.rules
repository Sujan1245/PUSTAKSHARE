rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Users Collection ---
    match /users/{userId} {
      function isValidUser(data) {
        return data.uid == request.auth.uid &&
               data.displayName is string && data.displayName.size() <= 100 &&
               data.email is string && data.email.size() <= 100 &&
               (data.get('bio', '') is string && data.get('bio', '').size() <= 500) &&
               (data.get('location', '') is string && data.get('location', '').size() <= 100);
      }

      allow get: if isSignedIn();
      allow list: if isSignedIn(); // Allow listing users for community browsing
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().createdAt == request.time;
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().uid == existing().uid &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'bio', 'location', 'booksOffered', 'booksBorrowed']);
    }

    // --- Books Collection ---
    match /books/{bookId} {
      function isValidBook(data) {
        return data.ownerId == request.auth.uid &&
               data.title is string && data.title.size() <= 200 &&
               data.author is string && data.author.size() <= 200 &&
               data.availabilityStatus in ['Available', 'Borrowed', 'Hidden'];
      }

      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidBook(incoming()) && incoming().createdAt == request.time;
      allow update: if isSignedIn() && isOwner(existing().ownerId) && isValidBook(incoming()) &&
                    incoming().ownerId == existing().ownerId &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().updatedAt == request.time;
      allow delete: if isSignedIn() && isOwner(existing().ownerId);
    }

    // --- Requests Collection ---
    match /requests/{requestId} {
      function isValidRequest(data) {
        return data.borrowerId == request.auth.uid &&
               isValidId(data.bookId) &&
               isValidId(data.lenderId) &&
               data.status == 'Pending';
      }

      allow read: if isSignedIn() && (isOwner(resource.data.borrowerId) || isOwner(resource.data.lenderId));
      allow create: if isSignedIn() && isValidRequest(incoming()) && incoming().createdAt == request.time;
      
      // Update logic: Lender can approve/reject, Borrower/Lender can mark returned?
      // Let's say Lender manages the lifecycle after request is sent.
      allow update: if isSignedIn() && (
        // Action: Lender approves or rejects
        (isOwner(existing().lenderId) && 
         incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']) &&
         incoming().status in ['Accepted', 'Rejected', 'Returned'] &&
         incoming().updatedAt == request.time) ||
        // Action: Borrower cancels pending request
        (isOwner(existing().borrowerId) && existing().status == 'Pending' &&
         incoming().status == 'Cancelled' &&
         incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']) &&
         incoming().updatedAt == request.time)
      );
    }
  }
}
